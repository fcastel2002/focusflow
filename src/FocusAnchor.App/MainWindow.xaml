<Window x:Class="FocusAnchor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FocusAnchor"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="650"
        Background="{DynamicResource PageBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid Margin="36,28,36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock FontSize="25"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Text="FocusAnchor" />
                <TextBlock Margin="0,4,0,0"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="Un espacio tranquilo para elegir y proteger tu atención." />
            </StackPanel>
            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <RadioButton x:Name="FocusSectionButton"
                             Content="Foco"
                             GroupName="HubSection"
                             IsChecked="True"
                             Style="{StaticResource NavigationTabStyle}"
                             Tag="Focus"
                             Checked="HubSection_Checked" />
                <RadioButton Content="Seguimiento"
                             GroupName="HubSection"
                             Style="{StaticResource NavigationTabStyle}"
                             Tag="History"
                             Checked="HubSection_Checked" />
                <RadioButton x:Name="CalendarSectionButton"
                             Content="Calendario"
                             GroupName="HubSection"
                             Style="{StaticResource NavigationTabStyle}"
                             Tag="Calendar"
                             Checked="HubSection_Checked" />
                <Button x:Name="ThemeButton"
                        Margin="4,0,0,0"
                        Padding="11,7"
                        Click="ToggleTheme_Click"
                        Content="Tema oscuro"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button x:Name="RainButton"
                        Margin="4,0,0,0"
                        Padding="11,7"
                        Click="ToggleRain_Click"
                        Content="Lluvia: reproducir"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Slider x:Name="RainVolumeSlider"
                        Width="76"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Maximum="1"
                        Minimum="0"
                        SmallChange="0.05"
                        TickFrequency="0.1"
                        ToolTip="Volumen de lluvia"
                        ValueChanged="RainVolumeSlider_ValueChanged" />
                <Border Margin="8,0,0,0"
                        Padding="12,7"
                        Background="{DynamicResource StatusBrush}"
                        CornerRadius="14">
                    <TextBlock x:Name="HeaderStatusText"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               Text="Listo para enfocar" />
                </Border>
            </StackPanel>
        </Grid>

        <Grid x:Name="StartPanel" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="8,56,48,0">
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           Text="TU PRÓXIMO BLOQUE" />
                <TextBlock Margin="0,16,0,0"
                           FontSize="46"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"
                           Text="Elegí una intención.&#x0a;El resto puede esperar." />
                <TextBlock Margin="0,22,0,0"
                           MaxWidth="500"
                           HorizontalAlignment="Left"
                           FontSize="17"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           LineHeight="26"
                           TextWrapping="Wrap"
                           Text="Una sesión de foco no es una lista de tareas. Es una decisión simple sobre dónde querés poner tu atención ahora." />
            </StackPanel>
            <Border Grid.Column="1"
                    Margin="12,14,8,14"
                    Style="{StaticResource CardStyle}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="Empezar una sesión" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="¿Qué merece tu atención ahora?" />
                    <TextBox x:Name="IntentTextBox"
                             Margin="0,22,0,0"
                             MinHeight="48"
                             Style="{StaticResource InputStyle}"
                             TextWrapping="Wrap" />
                    <TextBlock Margin="0,24,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="DURACIÓN" />
                    <StackPanel Margin="0,11,0,0" Orientation="Horizontal">
                        <RadioButton Content="25 min"
                                     GroupName="Duration"
                                     IsChecked="True"
                                     Style="{StaticResource DurationOptionStyle}"
                                     Tag="25"
                                     Checked="DurationOption_Checked" />
                        <RadioButton Content="45 min"
                                     GroupName="Duration"
                                     Style="{StaticResource DurationOptionStyle}"
                                     Tag="45"
                                     Checked="DurationOption_Checked" />
                        <RadioButton Content="60 min"
                                     GroupName="Duration"
                                     Style="{StaticResource DurationOptionStyle}"
                                     Tag="60"
                                     Checked="DurationOption_Checked" />
                    </StackPanel>
                    <TextBlock x:Name="StartErrorText"
                               Margin="0,18,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap" />
                    <Button Margin="0,24,0,0"
                            HorizontalAlignment="Stretch"
                            Click="StartSession_Click"
                            Content="Comenzar bloque de foco"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="SessionPanel"
              Grid.Row="1"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.18*" />
                <ColumnDefinition Width="0.82*" />
            </Grid.ColumnDefinitions>
            <Border Margin="0,0,18,0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Text="INTENCIÓN ACTUAL" />
                        <TextBlock x:Name="ActiveIntentText"
                                   Margin="0,10,0,0"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock x:Name="RemainingTimeText"
                                   HorizontalAlignment="Center"
                                   FontFamily="Consolas"
                                   FontSize="82"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="25:00" />
                        <TextBlock x:Name="SessionStatusText"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="15"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Sesión activa" />
                        <ProgressBar x:Name="SessionProgressBar"
                                     Height="8"
                                     Margin="28,32,28,0"
                                     Background="{DynamicResource SurfaceMutedBrush}"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource AccentBrush}"
                                     Maximum="100" />
                    </StackPanel>
                    <StackPanel Grid.Row="2"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                        <Button x:Name="PauseResumeButton"
                                Margin="0,0,10,0"
                                Click="PauseResume_Click"
                                Content="Pausar"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Margin="0,0,10,0"
                                Click="ShowFloating_Click"
                                Content="Usar modo flotante"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Click="EndSession_Click"
                                Content="Finalizar"
                                Style="{StaticResource DangerButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="Descargar una distracción" />
                    <TextBlock Grid.Row="1"
                               Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Text="Anotala sin cambiar de tarea. Va a quedar acá para cuando termine el bloque." />
                    <Grid Grid.Row="2" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DistractionTextBox"
                                 MinHeight="45"
                                 KeyDown="DistractionTextBox_KeyDown"
                                 Style="{StaticResource InputStyle}" />
                        <Button x:Name="CaptureDistractionButton"
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                Click="CaptureDistraction_Click"
                                Content="Anotar"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>
                    <ListBox x:Name="DistractionList"
                             Grid.Row="3"
                             Margin="0,22,0,0"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="14"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="ReviewPanel"
              Grid.Row="1"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="8,36,48,0">
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           Text="BLOQUE FINALIZADO" />
                <TextBlock Margin="0,14,0,0"
                           FontSize="42"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"
                           Text="Tomate un momento para revisar cómo fue." />
                <TextBlock x:Name="ReviewSummaryText"
                           Margin="0,22,0,0"
                           FontSize="16"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           LineHeight="25"
                           TextWrapping="Wrap" />
                <Button Margin="0,30,0,0"
                        HorizontalAlignment="Left"
                        Click="NewSession_Click"
                        Content="Elegir un nuevo foco"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </StackPanel>
            <Border Grid.Column="1"
                    Margin="12,14,8,14"
                    Style="{StaticResource CardStyle}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="Revisión breve" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Text="Opcional. Una nota simple para recordar qué pasó con tu atención." />
                    <TextBox x:Name="ReviewTextBox"
                             Height="150"
                             Margin="0,22,0,0"
                             AcceptsReturn="True"
                             Style="{StaticResource InputStyle}"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto" />
                    <TextBlock x:Name="ReviewSavedText"
                               Margin="0,16,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource PrimaryBrush}" />
                    <Button x:Name="SaveReviewButton"
                            Margin="0,22,0,0"
                            Click="SaveReview_Click"
                            Content="Guardar revisión"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="HistoryPanel"
              Grid.Row="1"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           Text="SEGUIMIENTO LOCAL" />
                <TextBlock Margin="0,9,0,0"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Text="Cómo viene tu atención" />
                <TextBlock Margin="0,7,0,0"
                           FontSize="15"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="Un registro descriptivo de tus bloques revisados, guardado en este dispositivo." />
                <Grid Margin="0,22,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Margin="0,0,12,0"
                            Padding="18"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="15">
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="BLOQUES REVISADOS" />
                            <TextBlock x:Name="HistorySessionCountText"
                                       Margin="0,8,0,0"
                                       FontSize="27"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="0" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1"
                            Margin="0,0,12,0"
                            Padding="18"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="15">
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="TIEMPO ENFOCADO" />
                            <TextBlock x:Name="HistoryFocusedTimeText"
                                       Margin="0,8,0,0"
                                       FontSize="27"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="0 min" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2"
                            Padding="18"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="15">
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="DISTRACCIONES ANOTADAS" />
                            <TextBlock x:Name="HistoryDistractionCountText"
                                       Margin="0,8,0,0"
                                       FontSize="27"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="Bloques recientes" />
                    <ListView x:Name="HistoryList"
                              Grid.Row="1"
                              Margin="0,16,0,0"
                              Background="Transparent"
                              BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="14"
                                        Background="{DynamicResource PageBackgroundBrush}"
                                        CornerRadius="10">
                                    <Grid Width="850">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Text="{Binding IntentDescription}" />
                                            <TextBlock Margin="0,5,0,0"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="{Binding Details}" />
                                            <TextBlock Margin="0,5,0,0"
                                                       FontSize="13"
                                                       FontStyle="Italic"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="{Binding Reflection}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Margin="18,0,0,0"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding EndedAt}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="CalendarPanel"
              Grid.Row="1"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.86*" />
                <ColumnDefinition Width="1.14*" />
            </Grid.ColumnDefinitions>

            <Border Margin="0,0,16,0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="Calendario de foco" />
                    <Calendar x:Name="PlanningCalendar"
                              Grid.Row="1"
                              Margin="0,14,0,0"
                              HorizontalAlignment="Stretch"
                              SelectedDatesChanged="PlanningCalendar_SelectedDateChanged" />
                    <StackPanel Grid.Row="2" Margin="0,18,0,0">
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="CALENDARIO LOCAL" />
                        <ComboBox x:Name="FocusCalendarCombo"
                                  Margin="0,8,0,0"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="FocusCalendarCombo_SelectionChanged" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CalendarNameTextBox"
                                     Style="{StaticResource InputStyle}" />
                            <TextBox x:Name="CalendarColorTextBox"
                                     Grid.Column="1"
                                     Margin="8,0,0,0"
                                     Style="{StaticResource InputStyle}"
                                     Text="#295C4D" />
                        </Grid>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Button x:Name="NewCalendarButton"
                                    Margin="0,0,8,0"
                                    Padding="11,7"
                                    Click="NewCalendar_Click"
                                    Content="Nuevo"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="SaveCalendarButton"
                                    Margin="0,0,8,0"
                                    Padding="11,7"
                                    Click="SaveCalendar_Click"
                                    Content="Guardar"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button x:Name="DeleteCalendarButton"
                                    Padding="11,7"
                                    Click="DeleteCalendar_Click"
                                    Content="Eliminar"
                                    Style="{StaticResource DangerButtonStyle}" />
                        </StackPanel>
                        <TextBlock Margin="0,20,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="GOOGLE CALENDAR OPCIONAL" />
                        <TextBlock x:Name="GoogleStatusText"
                                   Margin="0,7,0,0"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                        <ComboBox x:Name="GoogleCalendarCombo"
                                  Margin="0,8,0,0"
                                  DisplayMemberPath="Name" />
                        <StackPanel Margin="0,9,0,0" Orientation="Horizontal">
                            <Button x:Name="ConnectGoogleButton"
                                    Margin="0,0,7,0"
                                    Padding="10,6"
                                    Click="ConnectGoogle_Click"
                                    Content="Vincular Google"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="LinkGoogleCalendarButton"
                                    Margin="0,0,7,0"
                                    Padding="10,6"
                                    Click="LinkGoogleCalendar_Click"
                                    Content="Usar calendario"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="UnlinkGoogleCalendarButton"
                                    Padding="10,6"
                                    Click="UnlinkGoogleCalendar_Click"
                                    Content="Desvincular"
                                    Style="{StaticResource DangerButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="CalendarErrorText"
                               Grid.Row="3"
                               Margin="0,12,0,0"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="SelectedDateText"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock x:Name="DailySummaryText"
                               Margin="0,7,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />

                    <Border Margin="0,16,0,0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="Meta breve del día" />
                            <TextBox x:Name="DailyGoalTextBox"
                                     Margin="0,10,0,0"
                                     Style="{StaticResource InputStyle}" />
                            <Button x:Name="SaveDailyGoalButton"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Padding="11,7"
                                    Click="SaveDailyGoal_Click"
                                    Content="Guardar meta diaria"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,16,0,0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="Bloques planeados" />
                            <ListBox x:Name="PlanList"
                                     Height="112"
                                     Margin="0,10,0,0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     SelectionChanged="PlanList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="{Binding DisplayText}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="78" />
                                    <ColumnDefinition Width="78" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PlanIntentTextBox"
                                         Style="{StaticResource InputStyle}" />
                                <TextBox x:Name="PlanTimeTextBox"
                                         Grid.Column="1"
                                         Margin="8,0,0,0"
                                         Style="{StaticResource InputStyle}"
                                         Text="09:00" />
                                <TextBox x:Name="PlanDurationTextBox"
                                         Grid.Column="2"
                                         Margin="8,0,0,0"
                                         Style="{StaticResource InputStyle}"
                                         Text="25" />
                            </Grid>
                            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                <Button x:Name="NewPlanButton"
                                        Margin="0,0,8,0"
                                        Padding="11,7"
                                        Click="NewPlan_Click"
                                        Content="Nuevo"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button x:Name="SavePlanButton"
                                        Margin="0,0,8,0"
                                        Padding="11,7"
                                        Click="SavePlan_Click"
                                        Content="Guardar bloque"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <Button x:Name="StartPlanButton"
                                        Margin="0,0,8,0"
                                        Padding="11,7"
                                        Click="StartPlan_Click"
                                        Content="Empezar ahora"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button x:Name="DeletePlanButton"
                                        Padding="11,7"
                                        Click="DeletePlan_Click"
                                        Content="Eliminar"
                                        Style="{StaticResource DangerButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="0,20,0,0"
                   HorizontalAlignment="Center"
                   FontSize="12"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Text="FocusAnchor mantiene tu intención cerca, sin convertirla en una lista." />
    </Grid>
</Window>
