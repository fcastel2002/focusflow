<Window x:Class="FocusAnchor.App.FloatingTimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380"
        Height="205"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        Closed="Window_Closed"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Margin="10"
            Padding="18"
            Background="{StaticResource SurfaceBrush}"
            CornerRadius="18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              Direction="270"
                              Opacity="0.2"
                              ShadowDepth="4" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="FloatingStatusText"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               Text="SESIÓN ACTIVA" />
                    <TextBlock x:Name="FloatingIntentText"
                               Margin="0,5,12,0"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Button Grid.Column="1"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Click="OpenHub_Click"
                        Content="×"
                        Style="{StaticResource SecondaryButtonStyle}"
                        ToolTip="Volver al hub" />
            </Grid>
            <StackPanel Grid.Row="1"
                        Margin="0,12,0,0"
                        VerticalAlignment="Center">
                <TextBlock x:Name="FloatingTimeText"
                           FontFamily="Consolas"
                           FontSize="40"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Text="25:00" />
                <ProgressBar x:Name="FloatingProgressBar"
                             Height="5"
                             Margin="0,5,0,0"
                             Background="{StaticResource SurfaceMutedBrush}"
                             BorderThickness="0"
                             Foreground="{StaticResource AccentBrush}"
                             Maximum="100" />
            </StackPanel>
            <StackPanel Grid.Row="2"
                        Margin="0,14,0,0"
                        Orientation="Horizontal">
                <Button x:Name="FloatingPauseResumeButton"
                        Margin="0,0,8,0"
                        Padding="12,7"
                        Click="PauseResume_Click"
                        Content="Pausar"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Margin="0,0,8,0"
                        Padding="12,7"
                        Click="OpenHub_Click"
                        Content="Abrir hub"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button x:Name="FloatingEndButton"
                        Padding="12,7"
                        Click="EndSession_Click"
                        Content="Finalizar"
                        Style="{StaticResource DangerButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
